<?php
header('Content-Type: application/json');
include 'conexion.php';

$torneo_id = isset($_GET['torneo_id']) ? intval($_GET['torneo_id']) : 0;

$sql = "SELECT nombre_alumno, categoria, medalla
        FROM medallero_torneo
        WHERE torneo_id = $torneo_id
        ORDER BY 
          CASE medalla
            WHEN 'Oro' THEN 1
            WHEN 'Plata' THEN 2
            WHEN 'Bronce' THEN 3
            ELSE 4
          END";

$resultado = $conn->query($sql);

$medallero = [];

if ($resultado) {
    while ($fila = $resultado->fetch_assoc()) {
        $medallero[] = $fila;
    }

    echo json_encode([
        "ok" => true,
        "medallero" => $medallero
    ]);
} else {
    echo json_encode([
        "ok" => false,
        "mensaje" => "Error al listar medallero"
    ]);
}
?>
